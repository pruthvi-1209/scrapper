{
  "name": "marketverse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.17.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "clean": "yarn workspaces foreach -A run clean",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "dev": "concurrently \"yarn workspace @marketverse/server dev\" \"yarn workspace @marketverse/web dev\""
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
